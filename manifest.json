{
  "manifest_version": 3,
  "name": "TubeSkipper",
  "version": "1.0",
  "description": "Instantly skip YouTube ads. A lightweight, automatic ad-skipper for a seamless viewing experience.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
